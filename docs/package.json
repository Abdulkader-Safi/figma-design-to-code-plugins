{
  "name": "design-to-html-docs",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "rspress build",
    "check": "biome check --write",
    "dev": "rspress dev",
    "format": "biome format --write",
    "lint": "eslint .",
    "preview": "rspress preview",
