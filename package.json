{
  "name": "design-to-html",
  "version": "1.0.0",
  "description": "Your Figma Plugin",
  "main": "code.js",
  "scripts": {
    "build": "npm run build:ui && npm run build:js",
    "build:js": "esbuild src/main.ts --bundle --outfile=code.js --target=es2020",
    "build:ui": "tailwindcss -i src/ui/styles.css -o dist/ui.css --minify && node scripts/build-ui.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun run test/gradient.ts && bun run test/layout.ts && bun run test/breakpoints.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "watch": "esbuild src/main.ts --bundle --outfile=code.js --target=es2020 --watch"
  },
  "author": "",
  "license": "",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@figma/eslint-plugin-figma-plugins": "*",
    "@figma/plugin-typings": "^1.130.0",
    "@tailwindcss/cli": "^4.3.2",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
